# threat-model-generator — environment template
# Every key is optional. The deterministic rules-only mode runs without any.

# Anthropic Claude API for the optional --augment-with-llm step.
# https://console.anthropic.com/. Without this, the modeller first
# attempts a local Ollama fallback; without that either, augmentation
# is disabled and the model contains rules-only threats.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Local Ollama base URL (no key needed).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
